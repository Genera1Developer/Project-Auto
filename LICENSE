**package.json:**

```json
{
  "name": "web-proxy",
  "version": "1.0.0",
  "description": "A web proxy for Vercel and static serverless sites",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js"
  },
  "dependencies": {
    "express": "^4.17.1",
    "memoize-one": "^5.2.1",
    "request": "^2.88.2"
  },
  "license": "MIT"
}
```

