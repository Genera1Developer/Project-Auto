**New Files:**

* **src/index.js:** Web proxy implementation
* **src/utils/requestHandler.js:** Request handling utilities
* **src/utils/responseHandler.js:** Response handling utilities

**File Content:**

**package.json:**

```json
{
  "name": "web-proxy",
  "version": "1.0.0",
  "description": "A web proxy for Vercel and serverless sites",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js"
  },
  "dependencies": {
    "express": "^4.17.1"
  },
  "license": "MIT"
}
```

**src/index.js:**

```javascript
const express = require('express');
const app = express();
const requestHandler = require('./utils/requestHandler');
const responseHandler = require('./utils/responseHandler');

app.use(requestHandler);
app.use(responseHandler);

app.listen(3000, () => {
  console.log('Proxy listening on port 3000');
});
```

**src/utils/requestHandler.js:**

```javascript
const request = require('request');

module.exports = (req, res, next) => {
  const targetUrl = 'https://example.com';
  request(targetUrl, (error, response, body) => {
    if (error) {
      next(error);
    } else {
      res.locals.body = body;
      next();
    }
  });
};
```

**src/utils/responseHandler.js:**

```javascript
module.exports = (req, res) => {
  res.send(res.locals.body);
};
```