**package.json:**

```json
{
  "name": "web-proxy",
  "version": "1.0.0",
  "description": "A web proxy for Vercel and serverless sites",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js"
  },
  "dependencies": {
    "express": "^4.17.1",
    "request": "^2.88.2"
  },
  "license": "MIT"
}
```

**src/index.js:**

```javascript
const express = require('express');
const app = express();
const requestHandler = require('./utils/requestHandler');
const responseHandler = require('./utils/responseHandler');

app.use(express.json());
app.use(requestHandler);
app.use(responseHandler);

app.listen(3000, () => {
  console.log('Proxy listening on port 3000');
});
```

**src/utils/requestHandler.js:**

```javascript
const request = require('request');

module.exports = (req, res, next) => {
  const targetUrl = 'https://example.com';
  request(
    {
      url: targetUrl,
      method: req.method,
      headers: req.headers,
      body: req.body,
    },
    (error, response, body) => {
      if (error) {
        next(error);
      } else {
        res.locals.body = body;
        res.locals.headers = response.headers;
        next();
      }
    }
  );
};
```

**src/utils/responseHandler.js:**

```javascript
module.exports = (req, res) => {
  res.set(res.locals.headers);
  res.send(res.locals.body);
};
```

**Explanation:**

* We have added Express middleware to the proxy to support JSON requests.
* We have modified the requestHandler to pass the original request method, headers, and body to the target URL.
* We have added a responseHandler to set the response headers and send the body to the client.
* We have updated the description in package.json to reflect the proxy's functionality.