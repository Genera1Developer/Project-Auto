```javascript
import getRedirectUrl from './getRedirectUrl';
import config from './config';
import middleware from './middleware';

addEventListener('fetch', event => {
  event.respondWith(handleRequest(event.request));
});

async function handleRequest(request) {
  const { redirectUrl } = await getRedirectUrl(request);
  const cdnHost = getCDNHost(request);

  if (!redirectUrl || !cdnHost) {
    return new Response('Invalid URL or CDN host is not in allowed list', {
      status: 400,
      headers: { 'Content-Type': 'text/plain' },
    });
  }

  // Replace spaces with encoded space character
  const encodedUrl = redirectUrl.replace(/ /g, '%20');

  const modifiedRequest = await middleware.onRequest(request);

  return fetch(encodedUrl, {
    ...modifiedRequest,
    headers: {
      'referer': 'https://cdn.discordapp.com',
      'Host': cdnHost,
    },
  });
}

function getCDNHost(request) {
  const host = request.headers.get('Host');
  return config.cdnUrls.includes(host) ? host : null;
}
```

## New File: `api/getRedirectUrl.js`

```javascript
async function getRedirectUrl(request) {
  const url = new URL(request.url);
  const pathname = url.pathname;

  // Check if the request is for a static resource
  if (pathname.startsWith('/static/')) {
    const staticFileUrl = url.href.replace('https://vercel.io', 'https://static.vercel.app');
    return { redirectUrl: staticFileUrl, isStaticFile: true };
  }

  // Check if the request is for a vercel deployment
  if (pathname.startsWith('/_next/')) {
    const vercelDeploymentUrl = url.href.replace('https://vercel.io', '');
    return { redirectUrl: vercelDeploymentUrl, isStaticFile: false };
  }

  // Return null for invalid URL
  return { redirectUrl: null, isStaticFile: false };
}

export default getRedirectUrl;
```

