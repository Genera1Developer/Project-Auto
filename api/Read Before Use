## Modified `api/proxy.js`

```javascript
import getRedirectUrl from './getRedirectUrl';
import config from './config';
import middleware from './middleware';

addEventListener('fetch', event => {
  event.respondWith(handleRequest(event.request));
});

async function handleRequest(request) {
  const { redirectUrl, isStaticFile } = await getRedirectUrl(request);
  const cdnHost = getCDNHost(request);

  if (!redirectUrl || !cdnHost) {
    return new Response('Invalid URL or CDN host is not in allowed list', {
      status: 400,
      headers: { 'Content-Type': 'text/plain' },
    });
  }

  // Replace spaces with encoded space character
  const encodedUrl = redirectUrl.replace(/ /g, '%20');

  const modifiedRequest = await middleware.onRequest(request, isStaticFile);

  return fetch(encodedUrl, {
    ...modifiedRequest,
    headers: {
      'referer': 'https://cdn.discordapp.com',
      'Host': cdnHost,
    },
  });
}

function getCDNHost(request) {
  const host = request.headers.get('Host');
  return config.cdnUrls.includes(host) ? host : null;
}
```

