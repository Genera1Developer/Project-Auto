### Improved `api/proxy.js` File

```javascript
const { getAllowedHosts } = require('./config.js');

const proxy = async (req, res) => {
  // Get the request URL and host
  const { url, headers: { host } } = req;

  // Check if the host is allowed to be proxied
  if (!getAllowedHosts().includes(host)) {
    return res.status(403).json({ error: 'Host not allowed' });
  }

  // Modify the request URL to remove the host
  const newUrl = url.replace(`https://${host}`, '');

  // Set the origin header to the proxy host
  req.headers['origin'] = `https://${getAllowedHosts()[0]}`;

  // Perform the fetch request
  const fetchResponse = await fetch(newUrl, { headers: req.headers });

  // Proxy the response back to the client
  res.status(fetchResponse.status).json(await fetchResponse.json());
};

export default proxy;
```

