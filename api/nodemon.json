FILE PATH: api/controllers/proxy.controller.js
CONTENT:
```js
const fetch = require('node-fetch');
const config = require('../config/default');

const fetchProxy = async (req, res) => {
  try {
    const response = await fetch(`${config.protocol}://${config.hostname}:${config.port}/${req.url}`);
    const data = await response.text();
    res.header(config.headers);
    res.send(data);
  } catch (error) {
    res.status(500).send(error);
  }
};

module.exports = fetchProxy;
```