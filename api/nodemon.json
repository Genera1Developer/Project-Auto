FILE PATH: .github/workflows/proxy.yml
CONTENT: name: Proxy

on: [push]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: 16
      - run: npm ci
      - run: npm run build
      - uses: actions/upload-artifact@v3
        with:
          name: proxy-build
          path: build