file path: api/nodemon.json
content:
```json
{
  "watch": [
    "api/controllers/**/*.js",
    "api/models/**/*.js",
    "api/routes/**/*.js"
  ],
  "script": "nodemon --exec npm start",
  "ignore": [
    "node_modules/",
    ".git/",
    "logs/"
  ],
  "env": {
    "PORT": "3000",
    "DB_HOST": "localhost",
    "DB_USER": "root",
    "DB_PASS": "",
    "DB_NAME": "web_proxy"
  },
  "postStart": "npm run seed",
  "execMap": {
    "js": "node --harmony"
  }
}
```