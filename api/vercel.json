**Improved `api/vercel.yml` with Vercel's Python edge function support**

```yml
version: 2
builds:
  - src: ./src
    env:
      - PROJECT_ROOT=/opt/project
    use: "@vercel/python-edge"
    config:
      experimental: edge-functions
      exclude: node_modules/**
  - src: ./static
    use: cloudflare-pages
```

