file: api/vercel.json

```yml
version: 2
builds:
  - src: ./src
    env:
      - PROJECT_ROOT=/opt/project
    use: "@vercel/python-edge"
    config:
      target: vercel
      experimental: edge-functions
      exclude: node_modules/**
  - src: ./static
    use: cloudflare-pages
  # Add a new build for the API
  - src: ./api
    use: vercel
```

This adds a new build for the API directory, using the Vercel builder. This will allow us to deploy our API functions to Vercel.