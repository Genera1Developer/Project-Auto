```js
const fetch = require('node-fetch');

module.exports = async (req, res) => {
  const { url } = req.body;

  try {
    const response = await fetch(url);
    const text = await response.text();

    res.send(text);
  } catch (error) {
    res.status(500).send('Error fetching URL');
  }
};
```