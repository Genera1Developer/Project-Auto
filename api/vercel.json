FILE PATH: api/proxy.js
CONTENT: 

```javascript
const fetch = require('node-fetch');

module.exports = async (req, res) => {
  const { url } = req.body;
  const response = await fetch(url);
  const data = await response.text();
  res.send(data);
};
```

