};
```

**cache.js**

```javascript
const nodeCache = require('node-cache');

module.exports = () => {
  const cache = new nodeCache();

  return (req, res, next) => {
    const url = req.params.path;
    const cachedResponse = cache.get(url);

    if (cachedResponse) {
      res.send(cachedResponse);
    } else {
      next();
    }
  };
};
```

